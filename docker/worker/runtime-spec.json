{
  "benchmark_image": "sundai/simplefold-benchmark:latest",
  "gpu": {
    "count": 1,
    "capabilities": ["compute", "utility"]
  },
  "mounts": [
    {"source": "/srv/sundai/input_bundle", "target": "/input", "read_only": true},
    {"source": "/srv/sundai/output", "target": "/output", "read_only": false},
    {"source": "/srv/sundai/workspace", "target": "/workspace", "read_only": false}
  ],
  "network": "none",
  "timeout_sec": 600,
  "tmpfs": ["/tmp:size=8g"],
  "env": {
    "PYTHONUNBUFFERED": "1"
  }
}
